# ─────────────────────────────────────────────────────────────
# Lumitya Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Supabase — get from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
# Example for GitHub Pages custom domain + local dev:
ALLOWED_ORIGINS=https://www.lumitya.com,http://localhost:3000,http://localhost:8080

# Admin panel protection — use a long random secret (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-a-long-random-secret

# Node environment
NODE_ENV=production

# Port — Render injects this automatically; keep 3000 for local dev
PORT=3000
